# Carburants France — environment variables
#
# Copy this file to .env.local (which is gitignored) and fill in values.
# In CI (GitHub Actions), variables are injected via the deploy workflow's
# `env:` block at the build step, sourced from repository secrets.

# MapTiler API key (required for Vague 2 R1 — labels FR sur la carte)
# - Create account: https://cloud.maptiler.com/
# - Permission scope: tile access only (not geocoding/data)
# - Restrict by HTTP Referrer (allow-list `*.github.io/carburants-france/*`)
#   and configure HARD QUOTA CAP (not just alert) in dashboard
# - Note: this key is INLINED in the public JS bundle by Vite at build time.
#   The .env.local just keeps it out of source control. It is NOT a runtime secret.
VITE_MAPTILER_KEY=your_maptiler_key_here

# Stadia Maps API key (fallback if A3 parity test fails MapTiler)
# - Create account: https://stadiamaps.com/
# - Free tier non-commercial usage requires attribution
# - Same caveat: inlined in the bundle, not a runtime secret
# VITE_STADIA_KEY=your_stadia_key_here
